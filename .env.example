# ===== Ollama Configuration =====
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.3

# ===== Database =====
DATABASE_URL=sqlite:///stock_analysis.db

# ===== Scheduler Intervals (minutes) =====
REDDIT_SCRAPE_INTERVAL=5
NEWS_FETCH_INTERVAL=15
AI_ANALYSIS_INTERVAL=30

# ===== Notes =====
# Reddit scraping: Uses public JSON endpoints, NO API KEY REQUIRED
# News search: Uses DuckDuckGo, NO API KEY REQUIRED
# StockTwits: Uses public API, NO API KEY REQUIRED
# Ollama: Optional - install ollama locally for AI critical thinking
#         If not installed, system uses rule-based fallback analysis
